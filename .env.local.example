# ============================================================
# ContentForge — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ContentForge

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ------------------------------------------------------------
# PayFast (ZAR payments - South Africa)
# ------------------------------------------------------------
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase
NEXT_PUBLIC_PAYFAST_SANDBOX=true

# ------------------------------------------------------------
# Stripe (USD payments - International)
# ------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ------------------------------------------------------------
# Claude / Anthropic (Scripts, descriptions, brand voice)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key

# ------------------------------------------------------------
# Google Cloud (WaveNet Premium TTS + Imagen images)
# ------------------------------------------------------------
GOOGLE_API_KEY=your-google-cloud-api-key
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id

# ------------------------------------------------------------
# ElevenLabs (Ultra TTS)
# ------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ------------------------------------------------------------
# Kie.ai (Standard images via Nano Banana + VEO3 AI video)
# ------------------------------------------------------------
KIE_API_KEY=your-kie-ai-api-key

# ------------------------------------------------------------
# fal.ai (Kling 1.5 premium video motion)
# ------------------------------------------------------------
FAL_KEY=your-fal-ai-api-key

# ------------------------------------------------------------
# n8n (AI workflow orchestration on VPS)
# ------------------------------------------------------------
N8N_WEBHOOK_URL=https://your-vps-hostname:5678/webhook/contentforge
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# ------------------------------------------------------------
# VPS - Kokoro TTS (Self-hosted Standard voice)
# ------------------------------------------------------------
KOKORO_ENDPOINT=http://31.97.118.216:5099

# ------------------------------------------------------------
# OpenRouter (Fallback AI routing)
# ------------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key

# ------------------------------------------------------------
# Resend (Transactional email)
# ------------------------------------------------------------
RESEND_API_KEY=your-resend-key
EMAIL_FROM=noreply@contentforge.com

# ------------------------------------------------------------
# Cloudflare (CDN / Workers AI - optional)
# ------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
