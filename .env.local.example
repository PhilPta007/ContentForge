# ============================================================
# StudioStack — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=StudioStack

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ------------------------------------------------------------
# PayFast (ZAR payments - South Africa)
# ------------------------------------------------------------
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase
PAYFAST_SANDBOX=true

# ------------------------------------------------------------
# PayPal (USD payments - International)
# ------------------------------------------------------------
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_SANDBOX=true

# ------------------------------------------------------------
# Claude / Anthropic (Scripts, descriptions, brand voice)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key

# ------------------------------------------------------------
# Google Cloud (WaveNet Premium TTS + Imagen images)
# ------------------------------------------------------------
GOOGLE_API_KEY=your-google-cloud-api-key
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id

# ------------------------------------------------------------
# ElevenLabs (Ultra TTS)
# ------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ------------------------------------------------------------
# Kie.ai (Standard images via Nano Banana + VEO3 AI video)
# ------------------------------------------------------------
KIE_API_KEY=your-kie-ai-api-key

# ------------------------------------------------------------
# fal.ai (Kling 1.5 premium video motion)
# ------------------------------------------------------------
FAL_KEY=your-fal-ai-api-key

# ------------------------------------------------------------
# n8n (AI workflow orchestration on VPS)
# ------------------------------------------------------------
N8N_WEBHOOK_URL=https://your-vps-hostname:5678/webhook/studiostack
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret
N8N_CALLBACK_URL=https://studiostack.vercel.app/api/webhooks/n8n
# n8n REST API token (JWT from n8n settings — used by scripts/fix-n8n-curl.mjs)
N8N_API_TOKEN=

# ------------------------------------------------------------
# VPS - Kokoro TTS (Self-hosted Standard voice)
# ------------------------------------------------------------
KOKORO_ENDPOINT=http://31.97.118.216:5099

# ------------------------------------------------------------
# OpenRouter (Fallback AI routing)
# ------------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key

# ------------------------------------------------------------
# Resend (Transactional email)
# ------------------------------------------------------------
RESEND_API_KEY=your-resend-key
EMAIL_FROM=noreply@studiostack.com

# ------------------------------------------------------------
# Cron Jobs
# ------------------------------------------------------------
CRON_SECRET=

# ------------------------------------------------------------
# Cloudflare (CDN / Workers AI - optional)
# ------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
